# ============================================================
# Workspace : meercatch
# Reference template — actual .env is auto-generated by
# create-workspace.ps1 with correct port slot + random secrets.
# ============================================================

NODE_ENV=development
WORKSPACE_NAME=meercatch

# -- Ports (auto-assigned by create-workspace.ps1) --------
WEB_PORT=3000
API_PORT=4000
ADMIN_PORT=8080

# -- PostgreSQL (uncomment db service in docker-compose.yml)
POSTGRES_PORT=5432
POSTGRES_USER=meercatch_user
POSTGRES_PASSWORD=change-me
POSTGRES_DB=meercatch_db
DATABASE_URL=postgresql://meercatch_user:change-me@db:5432/meercatch_db

# -- Security (auto-generated — change before production) -
JWT_SECRET=change-me-in-production

# -- Server -----------------------------------------------
SERVER_IP=192.168.0.200
